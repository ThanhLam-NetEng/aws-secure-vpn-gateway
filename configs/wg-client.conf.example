[Interface]
# REPLACE WITH YOUR CLIENT PRIVATE KEY
PrivateKey = <YOUR_CLIENT_PRIVATE_KEY_HERE>
Address = 10.66.66.2/32,fd42:42:42::2/128

# FORCE DNS TO ADGUARD HOME SINKHOLE
DNS = 10.66.66.1

[Peer]
# REPLACE WITH YOUR SERVER PUBLIC KEY
PublicKey = <YOUR_SERVER_PUBLIC_KEY_HERE>
PresharedKey = <OPTIONAL_PRESHARED_KEY_HERE>

# Route all traffic through the VPN
AllowedIPs = 0.0.0.0/0, ::/0

# REPLACE WITH YOUR AWS EC2 PUBLIC IP
Endpoint = <YOUR_AWS_PUBLIC_IP_HERE>:51820
PersistentKeepalive = 25
